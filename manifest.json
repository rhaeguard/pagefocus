{
  "name": "pagefocus",
  "description": "focus on what's necessary on the page",
  "version": "0.1",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs", "declarativeNetRequest"],
  "host_permissions": [
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://api.twitter.com/*",
    "*://proxsee.pscp.tv/*",
    "*://chatgpt.com/*",
    "*://www.linkedin.com/*",
    "*://licdn.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "all-blocking-rules",
        "enabled": true,
        "path": "all-blocking-rules.json"
      }
    ]
  },
  "icons": {
    "128": "/images/logo_128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["cs_twitter.js", "content_script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["cs_linkedin.js", "content_script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["cs_linkedin_start_script.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["cs_linkedin_page_hook.js"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}
